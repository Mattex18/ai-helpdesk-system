    {
      "parameters": {
        "jsCode": "return [\n  {\n    json: {\n      mittente: $json.mittente,\n      oggetto: $json.oggetto,\n      messaggio: $json.messaggio,\n      categoria: $json.categoria,\n      priorita: $json.priorita,\n      sentimento: $json.sentimento,\n      risposta_ai: $json.risposta,\n      stato: \"Aperto\",\n      data_ricezione: new Date().toISOString()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
