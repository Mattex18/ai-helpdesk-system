    {
      "parameters": {
        "jsCode": "let text = $json.output;\n\n// prova a trovare JSON anche se incompleto\nconst start = text.indexOf('{');\nconst end = text.lastIndexOf('}');\n\nif (start === -1) {\n  throw new Error(\"JSON non trovato\");\n}\n\n// se manca la chiusura, NON crashare\nlet jsonString = text.slice(start, end !== -1 ? end + 1 : undefined);\n\n// prova a riparare JSON incompleto\nif (!jsonString.endsWith('}')) {\n  jsonString += '}';\n}\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(jsonString);\n} catch (e) {\n  return [{\n    json: {\n      error: \"JSON non valido\",\n      raw: text\n    }\n  }];\n}\n\nreturn [{ json: parsed }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        -144
      ],
      "id": "84cd5632-e0f7-45d1-b03c-bf8de8152c3b",
      "name": "Parser output AI"
